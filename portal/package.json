{
  "name": "fcp-embedded-screen-example-portal",
  "version": "0.0.0",
  "description": "SFD Portal demonstrating embedded screen integration with Siti Agri via iframe and SSO bridge",
  "sideEffects": false,
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build:frontend": "NODE_ENV=production webpack",
    "dev": "npm run frontend:watch & npm run server:watch wait",
    "docker:test": "npm run lint && mkdir -p coverage 2>/dev/null || true && docker compose -f compose.yml -f compose.test.yml run --build --rm portal",
    "frontend:watch": "NODE_ENV=development webpack --watch",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "server:watch": "nodemon --inspect=0.0.0.0 --ext js,json,njk --legacy-watch ./src",
    "start": "NODE_ENV=production node --use-strict .",
    "test": "TZ=UTC vitest run --coverage",
    "test:watch": "TZ=UTC vitest"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@hapi/crumb": "9.0.1",
    "@hapi/hapi": "21.4.0",
    "@hapi/inert": "7.1.0",
    "@hapi/scooter": "8.0.0",
    "@hapi/vision": "7.0.3",
    "@hapi/wreck": "18.1.2",
    "blankie": "5.0.0",
    "convict": "6.2.5",
    "govuk-frontend": "6.1.0",
    "joi": "18.0.1",
    "nunjucks": "3.2.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.3",
    "autoprefixer": "10.4.21",
    "cheerio": "1.1.0",
    "clean-webpack-plugin": "4.0.0",
    "copy-webpack-plugin": "14.0.0",
    "cssnano": "7.0.7",
    "cssnano-preset-default": "7.0.7",
    "eslint": "9.29.0",
    "neostandard": "0.12.1",
    "nodemon": "3.1.10",
    "postcss-load-config": "6.0.1",
    "postcss-loader": "8.1.1",
    "sass": "1.89.2",
    "sass-loader": "16.0.5",
    "source-map-loader": "5.0.0",
    "terser-webpack-plugin": "5.4.0",
    "vitest": "4.1.3",
    "webpack": "5.105.4",
    "webpack-assets-manifest": "6.2.1",
    "webpack-cli": "6.0.1"
  }
}
