{#
  Error page — shown when the facade API call fails.

  In the real system, this would appear if capd-externaldb-facade
  is unavailable or returns an error.
#}
{% extends "layout.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Sorry, there is a problem with the service</h1>
      <p class="govuk-body">{{ message }}</p>
      <p class="govuk-body">
        <a href="/business" class="govuk-link">Return to business overview</a>
      </p>
    </div>
  </div>
{% endblock %}
